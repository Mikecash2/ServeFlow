{
  "name": "serveflow",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "e2e"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace apps/api",
    "build:api": "npm run build --workspace apps/api",
    "test:api": "npm run test --workspace apps/api",
    "test:api:integration": "npm run test:integration --workspace apps/api",
    "db:generate": "npm run generate --workspace packages/db",
    "db:migrate": "npm run migrate --workspace packages/db",
    "db:seed": "npm run seed --workspace packages/db",
    "test:e2e": "npm run test --workspace e2e"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "embedded-postgres": "^18.4.0-beta.17",
    "unplugin-swc": "^1.5.9"
  }
}
